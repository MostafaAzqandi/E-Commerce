        {
          "name": "Get all products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var template = `",
                  "<style>",
                  "  body { font-family: Arial, sans-serif; padding: 10px; }",
                  "  h2 { color: #333; }",
                  "  table { border-collapse: collapse; width: 100%; }",
                  "  th { background-color: #FF6C37; color: white; padding: 10px 14px; text-align: left; }",
                  "  td { padding: 8px 14px; border-bottom: 1px solid #ddd; vertical-align: top; }",
                  "  tr:hover { background-color: #f5f5f5; }",
                  "  .badge {",
                  "    display: inline-block;",
                  "    background: #eee;",
                  "    border-radius: 4px;",
                  "    padding: 2px 8px;",
                  "    margin: 2px;",
                  "    font-size: 12px;",
                  "    color: #555;",
                  "  }",
                  "  .price { font-weight: bold; color: #2a9d8f; }",
                  "  .low-stock { color: #e63946; font-weight: bold; }",
                  "</style>",
                  "",
                  "<h2>Products ({{count}} items)</h2>",
                  "<table>",
                  "  <thead>",
                  "    <tr>",
                  "      <th>#</th>",
                  "      <th>Title</th>",
                  "      <th>Price</th>",
                  "      <th>Stock</th>",
                  "      <th>Categories</th>",
                  "    </tr>",
                  "  </thead>",
                  "  <tbody>",
                  "    {{#each products}}",
                  "    <tr>",
                  "      <td>{{index}}</td>",
                  "      <td>{{title}}</td>",
                  "      <td class=\"price\">\\${{price}}</td>",
                  "      <td class=\"{{stockClass}}\">{{remainings}}</td>",
                  "      <td>{{#each categories}}<span class=\"badge\">{{this}}</span>{{/each}}</td>",
                  "    </tr>",
                  "    {{/each}}",
                  "  </tbody>",
                  "</table>",
                  "`;",
                  "",
                  "try {",
                  "  var products = pm.response.json();",
                  "  var data = {",
                  "    count: products.length,",
                  "    products: products.map(function(p, i) {",
                  "      return {",
                  "        index: i + 1,",
                  "        title: p.title,",
                  "        price: p.price.toFixed(2),",
                  "        remainings: p.remainings,",
                  "        stockClass: p.remainings <= 10 ? 'low-stock' : '',",
                  "        categories: p.categories",
                  "      };",
                  "    })",
                  "  };",
                  "  pm.visualizer.set(template, data);",
                  "} catch (e) {",
                  "  pm.visualizer.set('<p style=\"color:red\">Error rendering visualization: ' + e.message + '</p>');",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
